{
  "name": "mahiro-skills",
  "private": true,
  "version": "0.1.9",
  "type": "module",
  "packageManager": "bun@1.2.22",
  "bin": {
    "mahiro-skills": "./src/cli.ts"
  },
  "scripts": {
    "cli": "bun ./src/cli.ts",
    "gemini:build-extension": "bun x esbuild skills/gemini/extension/background-src.js --bundle --outfile=skills/gemini/extension/background.js --format=esm --platform=browser",
    "gemini:verify": "bun run gemini:build-extension && bun run typecheck && bun test",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "mqtt": "^5.15.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
